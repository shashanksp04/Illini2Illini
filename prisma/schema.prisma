generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums (exact names and variants from BUILD_SPEC.md)

enum Role {
  USER
  ADMIN
}

enum ListingStatus {
  ACTIVE
  TAKEN
  EXPIRED
  DELETED
}

enum LeaseType {
  SUBLEASE
  LEASE_TAKEOVER
}

enum RoomType {
  PRIVATE_ROOM
  ENTIRE_UNIT
}

enum GenderPreference {
  MALE
  FEMALE
  ANY
}

enum Season {
  SPRING
  SUMMER
  FALL
  FULL_YEAR
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ExternalListingSource {
  REDDIT
}

// users

model User {
  id                String   @id @default(uuid()) @db.Uuid
  auth_user_id      String   @unique @db.Uuid
  email             String   @unique
  first_name        String?
  last_name         String?
  username          String   @unique
  profile_picture_url String?
  role              Role     @default(USER)
  is_banned         Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  listings       Listing[]
  reports        Report[]       @relation("UserReports")
  contact_events ContactEvent[]
  listing_views  ListingView[]

  @@map("users")
}

// listings

model Listing {
  id                 String           @id @default(uuid()) @db.Uuid
  owner_id           String           @db.Uuid
  title              String           @db.VarChar(100)
  monthly_rent       Int
  lease_type         LeaseType
  seasons            Season[]         @default([])
  start_date         DateTime         @db.Date
  end_date           DateTime         @db.Date
  exact_address      String
  nearby_landmark    String           @db.VarChar(80)
  total_bedrooms     Int
  total_bathrooms    Int              @default(1)
  room_type          RoomType
  furnished            Boolean
  utilities_included   Boolean
  open_to_negotiation  Boolean          @default(false)
  gender_preference    GenderPreference
  description        String           @db.VarChar(1000)
  status             ListingStatus    @default(ACTIVE)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @default(now()) @updatedAt

  owner   User           @relation(fields: [owner_id], references: [id])
  photos  ListingPhoto[]
  reports Report[]
  contact_events ContactEvent[]
  listing_views  ListingView[]

  @@index([status, created_at])
  @@index([monthly_rent])
  @@index([start_date, end_date])
  @@map("listings")
}

// listing_photos

model ListingPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  listing_id   String   @db.Uuid
  image_url    String
  display_order Int
  created_at   DateTime @default(now())

  listing Listing @relation(fields: [listing_id], references: [id])

  @@map("listing_photos")
}

// reports

model Report {
  id                  String        @id @default(uuid()) @db.Uuid
  listing_id          String        @db.Uuid
  reported_by_user_id String        @db.Uuid
  reason              String
  status              ReportStatus  @default(OPEN)
  created_at          DateTime      @default(now())

  listing      Listing @relation(fields: [listing_id], references: [id])
  reported_by  User    @relation("UserReports", fields: [reported_by_user_id], references: [id])

  @@unique([listing_id, reported_by_user_id])
  @@map("reports")
}

// contact_events

model ContactEvent {
  id              String   @id @default(uuid()) @db.Uuid
  listing_id      String   @db.Uuid
  viewer_user_id  String   @db.Uuid
  created_at      DateTime @default(now())

  listing Listing @relation(fields: [listing_id], references: [id])
  viewer  User    @relation(fields: [viewer_user_id], references: [id])

  @@map("contact_events")
}

// listing_views

model ListingView {
  id              String   @id @default(uuid()) @db.Uuid
  listing_id      String   @db.Uuid
  viewer_user_id  String?  @db.Uuid
  created_at      DateTime @default(now())

  listing Listing @relation(fields: [listing_id], references: [id])
  viewer  User?   @relation(fields: [viewer_user_id], references: [id])

  @@index([listing_id])
  @@index([viewer_user_id])
  @@map("listing_views")
}

// External aggregated listings (e.g. Reddit); not platform-verified posts.

model RedditListing {
  id                  String               @id @default(uuid()) @db.Uuid
  external_id         String               @unique
  source              ExternalListingSource @default(REDDIT)
  title               String
  description         String               @db.Text
  monthly_rent        Int?
  lease_type          LeaseType?
  start_date          DateTime?            @db.Date
  end_date            DateTime?            @db.Date
  room_type           RoomType?
  furnished           Boolean?
  utilities_included  Boolean?
  open_to_negotiation Boolean?
  gender_preference   GenderPreference?
  nearby_landmark     String?              @db.VarChar(500)
  total_bedrooms      Int?
  total_bathrooms     Int?
  exact_address       String?              @db.Text
  external_url        String
  source_created_at   DateTime
  raw_text            String?              @db.Text
  seasons             Season[]             @default([])
  /** Reddit-hosted image URLs in display order (may be empty). */
  image_urls          String[]             @default([])
  exclude             Boolean              @default(false)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @default(now()) @updatedAt

  @@index([exclude, source_created_at])
  @@map("reddit_listings")
}

